{
    "name": "@monorepo-example/monorepo",
    "private": true,
    "type": "module",
    "scripts": {
        "types": "bun tsc --build --verbose",
        "lint": "bun run eslint --config eslint.full.config.ts --cache --fix --quiet",
        "lint-fix": "bun run eslint --config eslint.full.config.ts --cache --fix",
        "lint-nocache": "bun run eslint --config eslint.full.config.ts --fix",
        "dev:frontend1": "bun run --cwd ./apps/frontend1 --env-file ../../.env dev",
        "dev:frontend2": "bun run --cwd ./apps/frontend2 --env-file ../../.env dev",
        "build": "bun run --cwd ./apps/frontend1 --env-file ../../.env build && bun run --cwd ./apps/frontend2 --env-file ../../.env build"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not ie <= 11",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "dependencies": {
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "tailwindcss": "^4.1.13",
        "zod": "^4.1.9"
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.0",
        "@eslint/js": "^9.36.0",
        "@stylistic/eslint-plugin": "^5.4.0",
        "@types/bun": "^1.3.5",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.1.9",
        "@typescript/analyze-trace": "^0.10.1",
        "eslint": "^9.36.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.4.0",
        "jiti": "^2.6.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.44.1",
        "vite": "^7.1.6"
    }
}
